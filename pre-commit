#!/usr/bin/env bash
set -eo pipefail
set -o errexit
set -o errtrace
shopt -s inherit_errexit

HOOKS_PATH=$(git config --get core.hooksPath)
HOOKS_PATH="${HOOKS_PATH/#\~/$HOME}" # expand ~to $HOME so it works also with cygwin

## Run repo pre-commit hook first
if [[ -f "./.git/hooks/pre-commit" ]]; then
    sh ./.git/hooks/pre-commit
fi

if [ -f .pre-commit-config.yaml ]; then
    pre-commit run
fi